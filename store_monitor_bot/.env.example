# ======================================================
# ملف الإعدادات البيئية (.env)
# ======================================================
# انسخ هذا الملف واسمّه .env
# ثم عبّئ جميع القيم بياناتك الحقيقية
# ⚠️ لا ترفع هذا الملف على GitHub أبداً!

# ======================================================
# 🤖 تيليغرام - احصل عليها من @BotFather
# ======================================================

# توكن البوت من @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# معرف مجموعة الإدارة (رقم سالب)
# اصنع مجموعة خاصة، أضف البوت، وابعث رسالة، ثم ابحث عن ID من:
# https://api.telegram.org/bot<TOKEN>/getUpdates
ADMIN_GROUP_ID=-1001234567890

# معرفات المديرين مفصولة بفاصلة (أرقام User ID)
# احصل على ID من @userinfobot
ADMIN_USER_IDS=123456789,987654321

# ======================================================
# 🗄️ PostgreSQL - قاعدة البيانات
# ======================================================
# صيغة: postgresql://username:password@host:port/dbname
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/store_monitor

# ======================================================
# ⚡ Redis
# ======================================================
REDIS_URL=redis://localhost:6379/0

# ======================================================
# 🌐 Admin Dashboard
# ======================================================
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# مفتاح سري عشوائي (غيّره لأي نص طويل عشوائي)
SECRET_KEY=change_this_to_a_very_long_random_secret_key_in_production

# ======================================================
# 📝 إعدادات أخرى
# ======================================================
LOG_LEVEL=INFO

# ======================================================
# 🤖 LongCat AI API (for intelligent product scraping)
# ======================================================
LONGCAT_API_KEY=your_longcat_api_key_here
AI_SCRAPING_ENABLED=true
AI_SCRAPING_MODE=fallback
